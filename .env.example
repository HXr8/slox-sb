# DeepSeek API key (required)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Matrix homeserver URL (required)
SLOX_HOMESERVER=http://127.0.0.1:8008

# LLM endpoint (optional, defaults to DeepSeek)
SLOX_LLM_BASE=https://api.deepseek.com
SLOX_LLM_MODEL=deepseek-chat

# Local fallback LLM (optional, for when cloud is unreachable)
# SLOX_LOCAL_LLM_BASE=http://127.0.0.1:1234/v1

# SearXNG web search (optional)
SLOX_SEARXNG_URL=http://127.0.0.1:8888

# Flux image generation (optional)
SLOX_FLUX_BASE_URL=http://100.109.129.12:8190

# Slox root path (optional, defaults to /srv/slox)
# SLOX_ROOT=/srv/slox
