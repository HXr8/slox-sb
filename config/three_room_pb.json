  "command_routing": {
    "SLOX TASK:": {
      "room": "#pb-debate:slox.local",
      "agents": "all",
      "cognitive_graph": true,
      "adjudicator": "@victor:slox.local",
      "description": "Full PB task - all agents debate, Victor adjudicates, Ava synthesises"
    },
    "SLOX IC:": {
      "room": "#pb-advisory:slox.local",
      "agents": [
        "@marcus:slox.local",
        "@julia:slox.local",
        "@doria:slox.local",
        "@oscar:slox.local",
        "@seraphina:slox.local",
        "@victor:slox.local"
      ],
      "cognitive_graph": true,
      "adjudicator": "@victor:slox.local",
      "description": "Investment committee review"
    },
    "SLOX WP:": {
      "room": "#pb-advisory:slox.local",
      "agents": [
        "@catherine:slox.local",
        "@grace:slox.local",
        "@xavier:slox.local",
        "@victor:slox.local"
      ],
      "cognitive_graph": false,
      "adjudicator": "@victor:slox.local",
      "description": "Wealth planning deep-dive"
    },
    "SLOX CREDIT:": {
      "room": "#pb-advisory:slox.local",
      "agents": [
        "@oscar:slox.local",
        "@grace:slox.local",
        "@catherine:slox.local",
        "@victor:slox.local"
      ],
      "cognitive_graph": false,
      "adjudicator": "@victor:slox.local",
      "description": "Credit & lending solution"
    },
    "SLOX INS:": {
      "room": "#pb-advisory:slox.local",
      "agents": [
        "@nadia:slox.local",
        "@grace:slox.local",
        "@catherine:slox.local",
        "@victor:slox.local"
      ],
      "cognitive_graph": false,
      "adjudicator": "@victor:slox.local",
      "description": "Insurance & protection review"
    },
    "SLOX RISK:": {
      "room": "#pb-advisory:slox.local",
      "agents": [
        "@victor:slox.local",
        "@grace:slox.local"
      ],
      "cognitive_graph": false,
      "adjudicator": "@victor:slox.local",
      "description": "Risk sweep / adverse news scan"
    },
    "SLOX COMPLIANCE:": {
      "room": "#pb-advisory:slox.local",
      "agents": [
        "@victor:slox.local"
      ],
      "cognitive_graph": false,
      "adjudicator": "@victor:slox.local",
      "description": "Compliance audit / regulatory review"
    },
    "SLOX S&T:": {
      "room": "#pb-advisory:slox.local",
      "agents": [
        "@seraphina:slox.local",
        "@marcus:slox.local",
        "@victor:slox.local"
      ],
      "cognitive_graph": false,
      "adjudicator": "@victor:slox.local",
      "description": "Market depth and execution analysis"
    }
  },
  "llm_config": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "max_tokens_sub_debate": 3000,
    "max_tokens_synthesis": 8192,
    "timeout_seconds": 90
  },
  "client_data": {
    "db_path": "/srv/slox_sb/data/client_profiles/clients.db",
    "total_clients": 15000,
    "default_nationalities": 50,
    "default_archetypes": 15,
    "simulation_years_per_client": 20
  },
  "market_data": {
    "confidence_tag_default": "DELAYED_15M",
    "max_staleness_seconds": 3600,
    "free_sources": [
      "yfinance",
      "fred",
      "exchangeratesapi",
      "trace"
    ],
    "fallback_to_synthetic": true
  }
}