  "rooms": {
    "debate_room": "#pb-debate:slox.local",
    "advisory_room": "#pb-advisory:slox.local",
    "synthesis_room": "#pb-synthesis:slox.local",
    "synthesis_room_alias": "#pb-synthesis:slox.local"
  },
  "room_agents": {
    "#pb-debate:slox.local": [
      "@grace:slox.local",
      "@marcus:slox.local",
      "@julia:slox.local",
      "@doria:slox.local",
      "@catherine:slox.local",
      "@oscar:slox.local",
      "@nadia:slox.local",
      "@victor:slox.local",
      "@xavier:slox.local",
      "@seraphina:slox.local",
      "@ava:slox.local"
    ],
    "#pb-advisory:slox.local": [
      "@grace:slox.local",
      "@marcus:slox.local",
      "@julia:slox.local",
      "@doria:slox.local",
      "@catherine:slox.local",
      "@oscar:slox.local",
      "@nadia:slox.local",
      "@victor:slox.local",
      "@xavier:slox.local",
